# =============================================
# Proof of Claw Agent — Environment Configuration
# =============================================
# Copy this file to .env and fill in real values.
# The agent will refuse to start with placeholder/zero values.

# Agent Configuration (REQUIRED)
AGENT_ID=alice-agent
ENS_NAME=alice.proofclaw.eth
PRIVATE_KEY=  # Your agent's private key (never commit this)

# Blockchain RPC (REQUIRED — get a key from Alchemy, Infura, etc.)
RPC_URL=
CHAIN_ID=11155111

# 0G Configuration (REQUIRED)
ZERO_G_INDEXER_RPC=https://indexer-storage-testnet.0g.ai
ZERO_G_COMPUTE_ENDPOINT=https://broker-testnet.0g.ai

# DM3 Messaging (REQUIRED)
DM3_DELIVERY_SERVICE_URL=

# Ledger (optional — required for hardware-signed approvals)
LEDGER_ORIGIN_TOKEN=

# Policy Configuration (REQUIRED)
ALLOWED_TOOLS=swap_tokens,transfer,query
ENDPOINT_ALLOWLIST=https://api.uniswap.org,https://api.0x.org
MAX_VALUE_AUTONOMOUS_WEI=1000000000000000000

# EIP-8004 Trustless Agents (optional — set after contract deployment)
EIP8004_IDENTITY_REGISTRY=
EIP8004_REPUTATION_REGISTRY=
EIP8004_VALIDATION_REGISTRY=
EIP8004_INTEGRATION_CONTRACT=

# 0G iNFT / ERC-7857 (optional — set after contract deployment)
INFT_CONTRACT=

# 0G Chain
ZERO_G_CHAIN_RPC=https://evmrpc-testnet.0g.ai
ZERO_G_CHAIN_ID=16602

# RISC Zero (optional — set after circuit compilation)
RISC_ZERO_VERIFIER_ADDRESS=
RISC_ZERO_IMAGE_ID=

# API
API_PORT=8420
ETHERSCAN_API_KEY=

# Google Calendar Integration (optional - for backend proxy)
USER_AUTH_KEY=
OPERATOR_AUTH_KEY=

# Google OAuth (frontend - get from https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=

# 1clawAI API Server (optional - for credential storage/retrieval)
ONECLAW_PORT=3456
ONECLAW_API_KEY=test-key
# ONECLAW_ENDPOINT=http://localhost:3456/v1  # Uncomment to use local server
