# =============================================
# Proof of Claw Agent — Environment Configuration
# =============================================
# Copy this file to .env and fill in real values.
# The agent will refuse to start with placeholder/zero values.

# ── Agent Configuration (REQUIRED) ──────────────────────────────────
AGENT_ID=alice-agent
ENS_NAME=alice.proofofclaw.eth
PRIVATE_KEY=  # Your agent's private key (never commit this)
SIGNER_MODE=private-key  # private-key or mnemonic

# ── Blockchain RPC (REQUIRED) ───────────────────────────────────────
# Get a key from Alchemy, Infura, etc.
RPC_URL=
CHAIN_ID=11155111

# ── 0G Configuration (REQUIRED) ─────────────────────────────────────
ZERO_G_INDEXER_RPC=https://indexer-storage-testnet.0g.ai
ZERO_G_COMPUTE_ENDPOINT=https://broker-testnet.0g.ai

# ── 0G Chain ────────────────────────────────────────────────────────
ZERO_G_CHAIN_RPC=https://evmrpc-testnet.0g.ai
ZERO_G_CHAIN_ID=16602

# ── DM3 Messaging (REQUIRED) ───────────────────────────────────────
DM3_DELIVERY_SERVICE_URL=

# ── Ledger (optional — required for hardware-signed approvals) ──────
LEDGER_ORIGIN_TOKEN=

# ── Policy Configuration (REQUIRED) ────────────────────────────────
ALLOWED_TOOLS=swap_tokens,transfer,query
ENDPOINT_ALLOWLIST=https://api.uniswap.org,https://api.0x.org
MAX_VALUE_AUTONOMOUS_WEI=1000000000000000000

# ── EIP-8004 Trustless Agents (optional — set after contract deployment)
EIP8004_IDENTITY_REGISTRY=
EIP8004_REPUTATION_REGISTRY=
EIP8004_VALIDATION_REGISTRY=
EIP8004_INTEGRATION_CONTRACT=

# ── ERC-8004 Agent Registry Adapter (set after DeploySwarm) ────────
ERC8004_REGISTRY_ADDRESS=

# ── SoulVault Swarm Coordination (set after DeploySwarm) ───────────
SOULVAULT_SWARM_CONTRACT=

# ── 0G iNFT / ERC-7857 (optional — set after contract deployment) ──
INFT_CONTRACT=

# ── Sepolia (for ENS and identity) ─────────────────────────────────
SEPOLIA_RPC_URL=
SEPOLIA_CHAIN_ID=11155111

# ── Sepolia Contract Addresses (set after Deploy.s.sol) ────────────
SEPOLIA_GROTH16_VERIFIER_ADDRESS=
SEPOLIA_VERIFIER_ADDRESS=
SEPOLIA_INFT_ADDRESS=
SEPOLIA_SOULVAULT_SWARM_ADDRESS=
SEPOLIA_ERC8004_REGISTRY_ADAPTER_ADDRESS=
SEPOLIA_EIP8004_INTEGRATION_ADDRESS=

# ── ENS (Sepolia) ──────────────────────────────────────────────────
ENS_REGISTRY=0x00000000000C2E074eC69A0dFb2997BA6C7d2e1e
ENS_RESOLVER=
ENS_REGISTRAR_CONTROLLER=

# ── RISC Zero (set after circuit compilation) ──────────────────────
# Build with: cd zkvm && cargo +risc0 build --release --target riscv32im-risc0-zkvm-elf -p proof-of-claw-guest
RISC_ZERO_VERIFIER_ADDRESS=
RISC_ZERO_IMAGE_ID=0xa2ad29fbb85c3aee3a8863ffcb1fa287f537d89473f44df19cb2065834f025d2
RISC_ZERO_GUEST_ELF_PATH=zkvm/target/riscv32im-risc0-zkvm-elf/release/proof-of-claw-guest

# ── API ─────────────────────────────────────────────────────────────
API_PORT=8420
ETHERSCAN_API_KEY=

# ── Google Calendar Integration (optional — for backend proxy) ─────
USER_AUTH_KEY=
OPERATOR_AUTH_KEY=

# ── Google OAuth (frontend) ─────────────────────────────────────────
# Get from https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=

# ── 1clawAI API Server (optional — credential storage/retrieval) ───
ONECLAW_PORT=3456
ONECLAW_API_KEY=
ONECLAW_ENDPOINT=https://api.1claw.xyz/v1
ONECLAW_AGENT_ID=
ONECLAW_VAULT_ID=

# =============================================
# Swarm Bridge Configuration
# =============================================
# Connect ProofOfClaw agents to swarmprotocol.fun

# Swarm Hub
SWARM_HUB_URL=https://swarmprotocol.fun
SWARM_ORG_ID=
SWARM_AGENT_NAME=ProofOfClaw Bridge
SWARM_AGENT_TYPE=Coordinator

# Bridge ports
BRIDGE_PORT=3002
BRIDGE_DEFAULT_CHANNEL=

# Identity mapping (JSON: { "alice.proofofclaw.eth": { "agentId": "...", "channelId": "..." } })
POC_AGENTS_JSON=
